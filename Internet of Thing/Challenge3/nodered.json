    {
        "id": "4210e8fc7ac3039d",
        "type": "function",
        "z": "0b25a34679899bc4",
        "name": "split topic",
        "func": "// Get topics array\nconst topics = msg.extractedTopics;\n\n// Get the original payload string\nlet rawPayload = msg.payload.Payload;\n\n// Ensure it's a string\nif (typeof rawPayload !== \"string\") {\n    rawPayload = \"\";\n}\n\n// If payload does not end with '}', truncate to the last valid '}'\nif (!rawPayload.trim().endsWith(\"}\")) {\n    const lastClosingBraceIndex = rawPayload.lastIndexOf(\"}\");\n    if (lastClosingBraceIndex !== -1) {\n        rawPayload = rawPayload.slice(0, lastClosingBraceIndex + 1);\n    } else {\n        rawPayload = \"\";\n    }\n}\n\n// Try to parse the payload string into an array of objects\nlet payloadArray;\ntry {\n    payloadArray = JSON.parse(\"[\" + rawPayload + \"]\");\n} catch (e) {\n    rawPayload = \"\";\n}\n\n// Pad or trim payloads to match topics\nconst mqttMsgs = topics.map((topic, index) => {\n    return {\n        topic: topic,\n        payload: index < payloadArray.length ? payloadArray[index] : \"\",\n        qos: 0,\n        retain: false\n    };\n});\n\nreturn [mqttMsgs];\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 860,
        "y": 620,
        "wires": [
            [
                "3d40f721c68b542e"
            ]
        ]
    },
    {
        "id": "88a7da621c6c5602",
        "type": "function",
        "z": "0b25a34679899bc4",
        "name": "extract topic",
        "func": "// extract topics form Info\nconst infoText = msg.payload.Info;\nconst matches = [...infoText.matchAll(/\\[(.*?)\\]/g)];\n\n// save to extractedTopics\nmsg.extractedTopics = matches.map(match => match[1]);\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 690,
