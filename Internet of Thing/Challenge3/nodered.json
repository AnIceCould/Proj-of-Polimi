    {
        "id": "b03ee1fda74b7c6b",
        "type": "function",
        "z": "0b25a34679899bc4",
        "name": "format pub_msg",
        "func": "// Get the original payload content\nlet originalPayload = msg.payload;\n// Check if some of the payload do not appear\nif (originalPayload.type == \"\" || originalPayload.lat == \"\" || originalPayload.long == \"\" || originalPayload.unit == \"\" || originalPayload.range == \"\" || originalPayload.description == \"\")\n    originalPayload = \"\";\n\n// Construct the new payload structure\nmsg.payload = {\n    \"id\": flow.get(\"id\"),\n    \"timestamp\": Date.now(),\n    \"topic\": msg.topic,\n    \"payload\": originalPayload\n};\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
