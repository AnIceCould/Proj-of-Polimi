    {
        "id": "4c17f0978b899643",
        "type": "function",
        "z": "0b25a34679899bc4",
        "name": "is ack",
        "func": "// Check if Info matches one of the three conditions (ACK)\nif (\n    msg.payload.Info.startsWith(\"Connect Ack\") ||\n    msg.payload.Info.startsWith(\"Subscribe Ack\") ||\n    msg.payload.Info.startsWith(\"Publish Ack\")\n) {\n    // global ACK counter\n    var ackCount = global.get(\"ackCount\");\n    ackCount += 1;\n    global.set(\"ackCount\", ackCount);\n    msg.ackCount = ackCount;\n\n    // Determine the ACK type\n    if (msg.payload.Info.startsWith(\"Connect Ack\")) {\n        msg.ackType = \"Connect Ack\";\n    } else if (msg.payload.Info.startsWith(\"Subscribe Ack\")) {\n        msg.ackType = \"Subscribe Ack\";\n    } else if (msg.payload.Info.startsWith(\"Publish Ack\")) {\n        msg.ackType = \"Publish Ack\";\n    }\n\n    return msg;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "// Initialize ackCount\nglobal.set(\"ackCount\", 0);",
        "finalize": "",
        "libs": [],
        "x": 510,
